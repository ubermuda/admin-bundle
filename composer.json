{
    "name": "ubermuda/admin-bundle",
    "description": "Reusable admin shell + listing framework for Symfony apps we own.",
    "type": "symfony-bundle",
    "license": "proprietary",
    "require": {
        "php": ">=8.4",
        "psr/log": "^3.0",
        "symfony/asset-mapper": "^7.2|^8.0",
        "symfony/config": "^7.2|^8.0",
        "symfony/dependency-injection": "^7.2|^8.0",
        "symfony/framework-bundle": "^7.2|^8.0",
        "symfony/http-foundation": "^7.2|^8.0",
        "symfony/http-kernel": "^7.2|^8.0",
        "symfony/security-bundle": "^7.2|^8.0",
        "symfony/twig-bundle": "^7.2|^8.0",
        "symfony/ux-icons": "^2.0|^3.0",
        "twig/twig": "^3.10",
        "symfony/ux-twig-component": "^2.0|^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "symfony/phpunit-bridge": "^7.2|^8.0"
    },
    "autoload": {
        "psr-4": {
            "Ubermuda\\AdminBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ubermuda\\AdminBundle\\Test\\": "test/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "symfony/flex": false
        }
    }
}
